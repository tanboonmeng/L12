<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
                <h2 class="text-center mb-4">Add New Expense</h2>
                <!-- Below codes define the form fields -->
                <!-- 'name' attribute is CRITICAL. It must match req.body.description -->
                <form action="/add" method="POST">
                    <div class="mb-3">
                        <label for="expense-desc" class="form-label">Description</label>
                        <input type="text" id="expense-desc" name="description" class="form-control" required placeholder="e.g. Weekly Grocery Run">
                    </div>
                    
                    <div class="mb-3">
                        <label for="expense-amt" class="form-label">Amount ($)</label>
                        <input type="number" id="expense-amt" name="amount" step="0.01" class="form-control" required placeholder="0.00">
                    </div>

                    <div class="mb-3">
                        <label for="expense-date" class="form-label">Date of Expense</label>
                        <input type="date" id="expense-date" name="date" class="form-control" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="expense-cat" class="form-label">Category</label>
                        <select id="expense-cat" name="category" class="form-select">
                            <option value="Food">Food</option>
                            <option value="Transport">Transport</option>
                            <option value="Groceries">Groceries</option>
                            <option value="Household">Household</option>
                            <option value="Healthcare">Healthcare</option>
                            <option value="Communication">Communication</option>
                            <option value="Utilities">Utilities</option>
                            <option value="Miscellaneous">Miscellaneous</option>
                        </select>
                    </div>

                    
                    <!-- Button triggers the browser to send all the form field values as an HTTP POST request.
                    <!-- And Navigates the user back to the homepage (/) when clicked -->
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Save Expense</button>
                        <a href="/" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>