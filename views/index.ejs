<%- include('partials/header') %>



<style>
    /*===================================================================================
           Global font and spacing styling for a clean, modern dashboard aesthetic 
    =====================================================================================*/

    /* Clean system typeface stack using built-in OS fonts for native rendering optimization */
    .dashboard-container {
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        letter-spacing: -0.01em;
    }

    /* Soft shadow and interaction depth for summary metrics panels */
    .premium-card {
        border: none !important;
        border-radius: 16px !important;
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        background: #ffffff;
    }
    
    .premium-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -4px rgba(0, 0, 0, 0.08), 0 4px 12px -2px rgba(0, 0, 0, 0.04) !important;
    }

    /* Refined layout style configuration for the data ledger grid enclosure */
    .ledger-card {
        border: none !important;
        border-radius: 16px !important;
        background: #ffffff;
        overflow: hidden;
    }

    /* Smooth backdrop row tracking highlight animation */
    .custom-table tbody tr {
        transition: background-color 0.2s ease;
    }
    
    .custom-table tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02) !important;
    }

    /* Micro-scale snappy transition styling for buttons */
    .btn-action {
        transition: transform 0.15s ease, box-shadow 0.15s ease !important;
        font-weight: 500;
        border-radius: 8px;
    }

    .btn-action:hover {
        transform: scale(1.03);
    }
    
    .quote-accent {
        border-left: 4px solid #0d6efd;
        padding-left: 15px;
        max-width: 700px;
        margin: 0 auto;
    }

    .action-column {
        min-width: 240px;
    }

    .action-column .btn {
        white-space: nowrap;
    }

    .action-button-group {
        display: inline-flex;
        flex-wrap: nowrap;
        gap: 0.35rem;
        justify-content: center;
        width: 100%;
    }
</style>

<%# ------------------------------------------------------------------------------------------------- %>
<%# Dashboard view template - Displays the main dashboard with all expense entries and budget summary %>
<%# ------------------------------------------------------------------------------------------------- %>

<div class="container dashboard-container mt-5 pb-5">
    
    <div class="text-center mb-5">
        <h1 class="display-6 fw-bold align-middle tracking-tight text-dark mb-3">
            <img src="/image/INVEST.png" 
                 class="img-fluid me-3" 
                 alt="Calculator Asset Icon" 
                 style="width: 72px; height: auto; vertical-align: -6px;">Portfolio Dashboard
        </h1>
        <div class="quote-accent mb-4">
            <p class="text-muted fst-italic m-0 fs-5">
                "Price is what you pay. Value is what you get"
                <span class="text-dark fw-semibold d-block mt-1 fs-6">— Warren Buffett</span>
            </p>
        </div>
        <div class="w-25 mx-auto"><hr class="text-muted opacity-25"></div>
    </div>

    <div class="row g-4 mb-5">
        
        <%# P/L card with dynamic alert styling display%>
        <div class="col-md-6">
            <div class="card premium-card h-100 shadow-sm overflow-hidden">
                <% if ( realizedProfitLoss < 0 ) { %>
                    <div class="card-header bg-danger bg-gradient text-white border-0 py-3 fw-bold tracking-wide text-uppercase small">
                        ⚠️ Loss Alert
                    </div>
                <% } else { %>
                    <div class="card-header bg-primary bg-gradient text-white border-0 py-3 fw-bold tracking-wide text-uppercase small">
                        💳 Realized Profit/Loss
                    </div>
                <% } %>
                <div class="card-body p-4 d-flex flex-column justify-content-center">
                    <h5 class="card-title text-muted text-uppercase fw-semibold tracking-wider mb-2" style="font-size: 0.8rem;">
                        Realized Profit/Loss
                    </h5>
                    <h2 class="card-text display-5 fw-bold m-0 <%= realizedProfitLoss < 0 ? 'text-danger' : 'text-success' %>">
                        $<%= realizedProfitLoss.toFixed(2) %>
                    </h2>
                </div>
            </div>
        </div>

        <%# Total investment amount card display %>
        <div class="col-md-6">
            <div class="card premium-card h-100 shadow-sm overflow-hidden">
                <div class="card-header bg-success bg-gradient text-white border-0 py-3 fw-bold tracking-wide text-uppercase small">
                    📈 Investment Tracker
                </div>
                <div class="card-body p-4 d-flex flex-column justify-content-center">
                    <h5 class="card-title text-muted text-uppercase fw-semibold tracking-wider mb-2" style="font-size: 0.8rem;">
                        Total Investments
                    </h5>
                    <h2 class="card-text display-5 fw-bold text-success m-0">
                        $<%= totalInvested.toFixed(2) %>
                    </h2>
                </div>
            </div>
        </div>

    </div>



    <%# -------------------------------------All recorded expenses card display------------------------------------------------------- %>

    <div class="card ledger-card shadow-sm">
        <div class="card-header bg-white border-bottom border-light p-4 d-flex justify-content-between align-items-center">
            <h4 class="m-0 fw-bold text-dark fs-5">All Recorded Investments</h4>
            
            <div class="d-flex gap-2">
                <%# Reset month button for the user to clear all investments %>
                <button class="btn btn-sm btn-outline-danger btn-action px-3 py-2 fw-semibold" onclick="triggerResetAlert()">
                    Reset
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            
            <%# Section for displaying all recorded investments %>
            <% if (portfolio.length === 0) { %>
                <div class="text-center py-5 my-4 text-muted">
                    <div class="fs-1 mb-2">📂</div>
                    <p class="m-0 fw-medium">No investments found.</p>
                    <p class="small text-secondary mt-1">Use the navigation bar above to add your first investment entry!</p>
                </div>
            <% } else { %>
                
                <div class="table-responsive">
                    <table class="table table-hover custom-table align-middle m-0">
                        <thead class="bg-light border-bottom border-light">
                            <tr class="text-secondary fw-semibold" style="font-size: 0.85rem;">
                                <th scope="col" class="ps-4 py-3">Date</th>
                                <th scope="col" class="py-3">Trade Type</th>
                                <th scope="col" class="py-3">Symbol</th>
                                <th scope="col" class="text-end py-3">Quantity</th>
                                <th scope="col" class="text-end py-3">Unit Price</th>
                                <th scope="col" class="text-end py-3">Commission</th>
                                <th scope="col" class="text-end py-3">Ave Price</th>
                                <th scope="col" class="text-end py-3">Total Cost</th>
                                <th scope="col" class="text-center pe-4 py-3 action-column" style="width: 240px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="border-0">
                            <% for (let i = 0; i < portfolio.length; i++) { %>
                                <tr class="text-dark" style="font-size: 0.95rem;">
                                    <td class="ps-4 py-3 text-secondary fw-medium"><%= portfolio[i].date %></td>
                                    <td class="py-3 fw-medium"><%= portfolio[i].tradeType %></td>
                                    <td class="py-3">
                                        <span class="badge rounded-pill bg-light text-secondary border border-secondary-subtle px-3 py-2 fw-semibold" style="font-size: 0.75rem;">
                                            <%= portfolio[i].Symbol %>
                                        </span>
                                    </td>
                                    <td class="text-end py-3 fw-bold text-dark"><%= portfolio[i].quantity %></td>
                                    <td class="text-end py-3 fw-bold text-dark">$<%= portfolio[i].unitPrice.toFixed(2) %></td>
                                    <td class="text-end py-3 fw-bold text-dark">$<%= portfolio[i].commission.toFixed(2) %></td>
                                    <td class="text-end py-3 fw-bold text-dark">$<%= portfolio[i].quantity !== 0 ? ((portfolio[i].quantity * portfolio[i].unitPrice + portfolio[i].commission) / portfolio[i].quantity).toFixed(2) : '0.00' %></td>
                                    <td class="text-end py-3 fw-bold text-dark">$<%= portfolio[i].totalCost.toFixed(2) %></td>

                                    <td class="text-center py-3 action-column">
                                        <%# Action buttons for editing and deleting investment entries, edit button hyperlink redirects the browser to Edit page
                                        while delete button triggering a confirmation alert before proceeding %>
                                        <div class="action-button-group">
                                            <% if (portfolio[i].tradeType === 'Buy') { %>
                                                <a href="/sell/<%= portfolio[i].id %>" class="btn btn-sm btn-info btn-action shadow-sm text-white fw-semibold">Sell</a>
                                            <% } %>
                                            <a href="/edit/<%= portfolio[i].id %>" class="btn btn-sm btn-warning btn-action shadow-sm text-dark fw-semibold">Edit</a>
                                            <button class="btn btn-sm btn-danger btn-action shadow-sm fw-semibold" onclick="triggerDeleteAlert('<%= portfolio[i].id %>')">
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
            <% } %>

        </div>
    </div>

    <%# ============================================================ %>
    <%# Set Budget Modal - posts new budget value to /set-budget route %>
    <%# ============================================================ %>
    <div class="modal fade" id="setBudgetModal" tabindex="-1" aria-labelledby="setBudgetModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px; border: none;">
                <form action="/set-budget" method="POST">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="setBudgetModalLabel">💰 Set Monthly Budget</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body pt-2">
                        <label for="budgetAmount" class="form-label fw-semibold">New Budget Amount ($)</label>
                        <input 
                            type="number" 
                            id="budgetAmount" 
                            name="budgetAmount" 
                            step="0.01" 
                            min="0" 
                            class="form-control" 
                            placeholder="e.g. 3000.00" 
                            required>
                        <small class="text-muted d-block mt-2">
                            Current budget: $<%= (loss + totalInvested).toFixed(2) %>
                        </small>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary btn-action" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary btn-action fw-semibold">Save Budget</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

<script>
    // Confirmation alert pop-up for deleting an individual investment entry, triggered by the delete button in the Actions column of the investments table
    function triggerDeleteAlert(investmentId) {
        let userChoice = confirm("Are you sure you want to delete this investment?");
        if (userChoice === true) {
            window.location.href = "/delete/" + investmentId;
        }
    }

    // Confirmation alert pop-up for resetting the entire investment portfolio, triggered by the reset button.
    function triggerResetAlert() {
        let severeCheck = confirm("⚠️ CRITICAL WARNING:\n\nAre you sure you want to clear ALL recorded investments!");
        if (severeCheck === true) {
            window.location.href = "/reset";
        }
    }
</script>

<%- include('partials/footer') %>