<%- include('partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
                <h2 class="text-center mb-4">Sell Transaction</h2>
                <form action="/sell/<%= id %>" method="POST">
                    <div class="mb-3">
                        <label for="portfolio-symbol" class="form-label">Symbol</label>
                        <input type="text" id="portfolio-symbol" class="form-control" value="<%= investment.Symbol %>" disabled>
                        <input type="hidden" name="symbol" value="<%= investment.Symbol %>">
                    </div>

                    <div class="mb-3">
                        <label for="portfolio-tradeType" class="form-label">Trade Type</label>
                        <input type="text" id="portfolio-tradeType" class="form-control" value="Sell" disabled>
                        <input type="hidden" name="tradeType" value="Sell">
                    </div>

                    <div class="mb-3">
                        <label for="portfolio-quantity" class="form-label">Quantity</label>
                        <input type="number" id="portfolio-quantity" name="quantity" step="100" class="form-control" value="<%= investment.quantity %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="portfolio-unitprice" class="form-label">Unit Price ($)</label>
                        <input type="number" id="portfolio-unitprice" name="unitPrice" step="0.01" class="form-control" value="<%= investment.unitPrice %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="portfolio-commission" class="form-label">Commission ($)</label>
                        <input type="number" id="portfolio-commission" name="commission" step="0.01" class="form-control" value="<%= investment.commission %>" readonly>
                    </div>

                    <div class="mb-3">
                        <label for="portfolio-date" class="form-label">Date</label>
                        <input type="date" id="portfolio-date" name="date" class="form-control" value="<%= investment.date %>" required>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">Submit Sell</button>
                        <a href="/" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
